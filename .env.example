# ============================================================
# .env.example — vzorovy soubor env promennych pro MongoDB cluster
# Zkopirujte do .env a pripadne upravte hesla pred produkci.
# V akademickem prostredi lze pouzit vychozi hodnoty.
# ============================================================

# --- MongoDB credentials (admin uzivatel s roli root) ---
MONGO_ADMIN_USER=admin
MONGO_ADMIN_PASSWORD=adminpass123

# --- Aplikacni uzivatel (readWrite na filmdb) ---
MONGO_APP_USER=filmuser
MONGO_APP_PASSWORD=filmpass123

# --- Database ---
MONGO_DB_NAME=filmdb

# --- Mongos connection string pouzity v data-import kontejneru ---
MONGO_URI=mongodb://filmuser:filmpass123@mongos1:27017/filmdb?authSource=admin

# --- Porty exponované na hostiteli ---
MONGOS1_PORT=27117
MONGOS2_PORT=27118
COMPASS_WEB_PORT=3000
